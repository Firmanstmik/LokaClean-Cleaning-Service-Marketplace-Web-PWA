generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis]
}

model User {
  id                Int                @id @default(autoincrement())
  full_name         String
  email             String             @unique
  phone_number      String
  profile_photo     String?
  default_latitude  Float?
  default_longitude Float?
  role              Role               @default(USER)
  created_at        DateTime           @default(now())
  updated_at        DateTime           @updatedAt
  password_hash     String?
  cleanerProfile    CleanerProfile?
  notifications     Notification[]
  pesanan           Pesanan[]
  pushSubscriptions PushSubscription[]
  savedAddresses    SavedAddress[]
}

model SavedAddress {
  id             Int                       @id @default(autoincrement())
  user_id        Int
  label          String
  is_primary     Boolean                   @default(false)
  address        String
  street         String?
  village        String?
  district       String?
  city           String?
  notes          String?
  floor_number   String?
  building_name  String?
  gate_photo_url String?
  latitude       Float
  longitude      Float
  location       Unsupported("geography")?
  created_at     DateTime                  @default(now())
  updated_at     DateTime                  @updatedAt
  user           User                      @relation(fields: [user_id], references: [id])

  @@index([user_id])
}

model Admin {
  id                Int                @id @default(autoincrement())
  full_name         String
  email             String             @unique
  password          String
  role              Role               @default(ADMIN)
  created_at        DateTime           @default(now())
  phone_number      String?            @unique
  theme_settings    Json?
  pesanan           Pesanan[]
  pushSubscriptions PushSubscription[] @relation("AdminPushSubscriptions")
}

model CleanerProfile {
  id            Int                       @id @default(autoincrement())
  user_id       Int                       @unique
  rating        Float                     @default(5.0)
  active_orders Int                       @default(0)
  is_active     Boolean                   @default(true)
  created_at    DateTime                  @default(now())
  updated_at    DateTime                  @updatedAt
  location      Unsupported("geography")?
  user          User                      @relation(fields: [user_id], references: [id])
}

model ServiceArea {
  id         Int      @id @default(autoincrement())
  name       String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model PaketCleaning {
  id                  Int       @id @default(autoincrement())
  name                String
  description         String
  base_price          Int       @map("price")
  estimated_duration  Int
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt
  image               String?
  category            String    @default("SERVICE")
  description_en      String?
  name_en             String?
  stock               Int       @default(100)
  discount_percentage Int       @default(0)
  discount_edition    String?
  final_price         Int       @default(0)
  pricing_note        String?
  pesanan             Pesanan[]
}

model Pesanan {
  id                 Int                       @id @default(autoincrement())
  user_id            Int
  admin_id           Int?
  paket_id           Int
  status             OrderStatus               @default(PENDING)
  room_photo_before  String
  room_photo_after   String?
  location_latitude  Float
  location_longitude Float
  address            String
  scheduled_date     DateTime
  created_at         DateTime                  @default(now())
  updated_at         DateTime                  @updatedAt
  order_number       Int                       @unique
  base_price         Int                       @default(50000)
  distance_price     Int                       @default(0)
  estimated_eta      Int?
  surge_multiplier   Float                     @default(1.0)
  total_price        Int
  location           Unsupported("geography")?
  extra_price        Int                       @default(0)
  extra_services     Json?
  notifications      Notification[]
  pembayaran         Pembayaran?
  admin              Admin?                    @relation(fields: [admin_id], references: [id])
  paket              PaketCleaning             @relation(fields: [paket_id], references: [id])
  user               User                      @relation(fields: [user_id], references: [id])
  rating             Rating?
  tip                Tip?

  @@index([user_id])
  @@index([admin_id])
  @@index([paket_id])
}

model Pembayaran {
  id                Int           @id @default(autoincrement())
  pesanan_id        Int           @unique
  method            PaymentMethod
  amount            Int
  status            PaymentStatus @default(PENDING)
  created_at        DateTime      @default(now())
  midtrans_order_id String?
  pesanan           Pesanan       @relation(fields: [pesanan_id], references: [id])
}

model Rating {
  id           Int      @id @default(autoincrement())
  pesanan_id   Int      @unique
  rating_value Int
  review       String?
  created_at   DateTime @default(now())
  pesanan      Pesanan  @relation(fields: [pesanan_id], references: [id])
}

model Tip {
  id         Int      @id @default(autoincrement())
  pesanan_id Int      @unique
  amount     Int
  created_at DateTime @default(now())
  pesanan    Pesanan  @relation(fields: [pesanan_id], references: [id])
}

model Notification {
  id         Int      @id @default(autoincrement())
  user_id    Int
  pesanan_id Int?
  title      String
  message    String
  is_read    Boolean  @default(false)
  created_at DateTime @default(now())
  pesanan    Pesanan? @relation(fields: [pesanan_id], references: [id])
  user       User     @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@index([pesanan_id])
}

model PushSubscription {
  id         Int      @id @default(autoincrement())
  user_id    Int?
  endpoint   String   @unique
  p256dh     String
  auth       String
  created_at DateTime @default(now())
  admin_id   Int?
  admin      Admin?   @relation("AdminPushSubscriptions", fields: [admin_id], references: [id])
  user       User?    @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@index([admin_id])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model spatial_ref_sys {
  srid      Int     @id
  auth_name String? @db.VarChar(256)
  auth_srid Int?
  srtext    String? @db.VarChar(2048)
  proj4text String? @db.VarChar(2048)
}

enum Role {
  USER
  ADMIN
  CLEANER
}

enum OrderStatus {
  PENDING
  PROCESSING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  QRIS
  DANA
  TRANSFER
  CASH
}

enum PaymentStatus {
  PENDING
  PAID
}
